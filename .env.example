# Required
FRED_API_KEY=your_fred_api_key_here      # https://fred.stlouisfed.org/docs/api/api_key.html
EIA_API_KEY=your_eia_api_key_here        # https://api.eia.gov/

# Optional — set to restrict CORS (defaults to market-dashboards.vercel.app)
ALLOWED_ORIGIN=https://market-dashboards.vercel.app

# Hormuz dashboard only
ACLED_EMAIL=your_email@example.com       # https://acleddata.com/
ACLED_PASSWORD=your_acled_password
FIRMS_MAP_KEY=your_nasa_firms_key        # https://firms.modaps.eosdis.nasa.gov/
