{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=90" }
      ]
    }
  ],
  "functions": {
    "api/quote.js":  { "memory": 256, "maxDuration": 30 },
    "api/quotes.js": { "memory": 256, "maxDuration": 30 },
    "api/acled.js":  { "memory": 256, "maxDuration": 30 },
    "api/gdacs.js":  { "memory": 256, "maxDuration": 15 },
    "api/rss.js":    { "memory": 128, "maxDuration": 15 },
    "api/fires.js":  { "runtime": "edge" }
  }
}
